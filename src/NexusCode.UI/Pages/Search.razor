@page "/search"
@using NexusCode.UI.Services
@using NexusCode.Domain
@inject NexusService Nexus

<h1>Symbol Search</h1>

<div class="card">
    <div class="input-group">
        <input @bind="query" @bind:event="oninput" @onkeydown="SearchKeyDown" placeholder="Search symbols..." class="input" />
        <select @bind="kindFilter" class="select">
            <option value="">All</option>
            <option value="Type">Types</option>
            <option value="Method">Methods</option>
            <option value="Property">Properties</option>
            <option value="Field">Fields</option>
        </select>
        <button @onclick="Search" class="btn btn-primary">Search</button>
    </div>
</div>

@if (results.Count > 0)
{
    <div class="card">
        <h2>Results (@results.Count)</h2>
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Kind</th>
                    <th>File</th>
                    <th>Line</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in results)
                {
                    <tr>
                        <td><code>@r.Symbol.FullName</code></td>
                        <td>@r.Symbol.Kind</td>
                        <td>@Path.GetFileName(r.Symbol.FilePath)</td>
                        <td>@r.Symbol.StartLine</td>
                        <td>@r.Score.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (selectedSymbol != null)
{
    <div class="card">
        <h2>@selectedSymbol.FullName</h2>
        <p><strong>Kind:</strong> @selectedSymbol.Kind</p>
        <p><strong>File:</strong> @selectedSymbol.FilePath:@selectedSymbol.StartLine</p>
        <p><strong>Access:</strong> @selectedSymbol.AccessModifier</p>

        @if (callers.Count > 0)
        {
            <h3>Callers</h3>
            <ul>
                @foreach (var c in callers)
                {
                    <li>@c.Symbol.FullName</li>
                }
            </ul>
        }

        @if (callees.Count > 0)
        {
            <h3>Callees</h3>
            <ul>
                @foreach (var c in callees)
                {
                    <li>@c.Symbol.FullName</li>
                }
            </ul>
        }
    </div>
}

@code {
    private string query = "";
    private string kindFilter = "";
    private List<SearchResult> results = new();
    private SymbolEntity? selectedSymbol;
    private List<CalleeInfo> callers = new();
    private List<CalleeInfo> callees = new();

    private void SearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Search();
    }

    private void Search()
    {
        if (string.IsNullOrWhiteSpace(query)) return;

        SymbolKind? kind = kindFilter switch
        {
            "Type" => SymbolKind.Type,
            "Method" => SymbolKind.Method,
            "Property" => SymbolKind.Property,
            "Field" => SymbolKind.Field,
            _ => null
        };

        results = Nexus.SearchEngine.FindSymbol(query, new SearchOptions { KindFilter = kind, MaxResults = 50 }).ToList();
    }

    private void SelectSymbol(SymbolEntity symbol)
    {
        selectedSymbol = symbol;
        callers = Nexus.SearchEngine.FindCallers(symbol.Id, 1).ToList();
        callees = Nexus.SearchEngine.FindCallees(symbol.Id, 1).ToList();
    }
}
