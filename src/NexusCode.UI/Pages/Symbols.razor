@page "/symbols"
@using NexusCode.UI.Services
@using NexusCode.Domain
@inject NexusService Nexus

<h1>Symbol Browser</h1>

@if (!Nexus.IsIndexed)
{
    <div class="card">
        <p>Index a repository first from the <a href="/">Dashboard</a>.</p>
    </div>
}
else
{
    <div class="card">
        <div class="input-group">
            <input @bind="searchQuery" @bind:event="oninput" @onkeydown="SearchKeyDown" placeholder="Search symbols..." class="input" />
            <select @bind="kindFilter" class="select">
                <option value="">All Types</option>
                <option value="Type">Classes</option>
                <option value="Method">Methods</option>
                <option value="Property">Properties</option>
                <option value="Field">Fields</option>
                <option value="Event">Events</option>
            </select>
            <button @onclick="Search" class="btn btn-primary">Search</button>
        </div>
    </div>

    @if (results.Count > 0)
    {
        <div class="card">
            <h2>Results (@results.Count symbols)</h2>
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Kind</th>
                        <th>File</th>
                        <th>Line</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in results.Take(50))
                    {
                        <tr @onclick="() => SelectSymbol(s)" style="cursor:pointer">
                            <td><code>@s.FullName</code></td>
                            <td>@s.Kind</td>
                            <td>@Path.GetFileName(s.FilePath)</td>
                            <td>@s.StartLine</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (selectedSymbol != null)
    {
        <div class="card">
            <h2>@selectedSymbol.FullName</h2>
            <div class="symbol-details">
                <p><strong>Kind:</strong> @selectedSymbol.Kind</p>
                <p><strong>File:</strong> @selectedSymbol.FilePath:@selectedSymbol.StartLine-@selectedSymbol.EndLine</p>
                <p><strong>Access:</strong> @selectedSymbol.AccessModifier</p>
                @if (selectedSymbol.ReturnType != null)
                {
                    <p><strong>Returns:</strong> @selectedSymbol.ReturnType</p>
                }
            </div>

            @if (callers.Count > 0)
            {
                <h3>Callers (@callers.Count)</h3>
                <table class="table">
                    <thead><tr><th>Method</th><th>File</th></tr></thead>
                    <tbody>
                        @foreach (var c in callers)
                        {
                            <tr><td>@c.Symbol.FullName</td><td>@Path.GetFileName(c.Symbol.FilePath)</td></tr>
                        }
                    </tbody>
                </table>
            }

            @if (callees.Count > 0)
            {
                <h3>Callees (@callees.Count)</h3>
                <table class="table">
                    <thead><tr><th>Method</th><th>File</th></tr></thead>
                    <tbody>
                        @foreach (var c in callees)
                        {
                            <tr><td>@c.Symbol.FullName</td><td>@Path.GetFileName(c.Symbol.FilePath)</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <div class="card">
        <h2>Symbol Statistics</h2>
        <div class="kind-grid">
            <div class="kind-item"><span class="kind-name">Classes</span><span class="kind-count">@classCount</span></div>
            <div class="kind-item"><span class="kind-name">Methods</span><span class="kind-count">@methodCount</span></div>
            <div class="kind-item"><span class="kind-name">Properties</span><span class="kind-count">@propertyCount</span></div>
            <div class="kind-item"><span class="kind-name">Fields</span><span class="kind-count">@fieldCount</span></div>
            <div class="kind-item"><span class="kind-name">Events</span><span class="kind-count">@eventCount</span></div>
            <div class="kind-item"><span class="kind-name">Interfaces</span><span class="kind-count">@interfaceCount</span></div>
        </div>
    </div>
}

@code {
    private string searchQuery = "";
    private string kindFilter = "";
    private List<SymbolEntity> results = new();
    private SymbolEntity? selectedSymbol;
    private List<CallerInfo> callers = new();
    private List<CalleeInfo> callees = new();

    private int classCount => Nexus.SymbolTable.GetByKind(SymbolKind.Type).Count(s => s.TypeName == "Class");
    private int methodCount => Nexus.SymbolTable.GetByKind(SymbolKind.Method).Count;
    private int propertyCount => Nexus.SymbolTable.GetByKind(SymbolKind.Property).Count;
    private int fieldCount => Nexus.SymbolTable.GetByKind(SymbolKind.Field).Count;
    private int eventCount => Nexus.SymbolTable.GetByKind(SymbolKind.Event).Count;
    private int interfaceCount => Nexus.SymbolTable.GetByKind(SymbolKind.Type).Count(s => s.TypeName == "Interface");

    private void SearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Search();
    }

    private void Search()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            // Show all symbols if no query
            results = Nexus.SymbolTable.GetByKind(SymbolKind.Type)
                .Concat(Nexus.SymbolTable.GetByKind(SymbolKind.Method))
                .Concat(Nexus.SymbolTable.GetByKind(SymbolKind.Property))
                .Take(100).ToList();
            return;
        }

        SymbolKind? kind = kindFilter switch
        {
            "Type" => SymbolKind.Type,
            "Method" => SymbolKind.Method,
            "Property" => SymbolKind.Property,
            "Field" => SymbolKind.Field,
            "Event" => SymbolKind.Event,
            _ => null
        };

        results = Nexus.SearchEngine.FindSymbol(searchQuery, new SearchOptions { KindFilter = kind, MaxResults = 100 })
            .Select(r => r.Symbol).ToList();
    }

    private void SelectSymbol(SymbolEntity symbol)
    {
        selectedSymbol = symbol;
        callers = Nexus.SearchEngine.FindCallers(symbol.Id, 1).ToList();
        callees = Nexus.SearchEngine.FindCallees(symbol.Id, 1).ToList();
    }
}
